<Window x:Class="BluetoothDeskApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding AppWindowTitle}" Height="780" Width="1260" WindowStartupLocation="CenterScreen" WindowState="Maximized"
        Background="#E8EFEF" FontFamily="Bahnschrift" Opacity="0">
  <Window.Triggers>
    <EventTrigger RoutedEvent="Window.Loaded">
      <BeginStoryboard>
        <Storyboard>
          <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.35" />
        </Storyboard>
      </BeginStoryboard>
    </EventTrigger>
  </Window.Triggers>
  <Window.Resources>
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PrimaryBrush" Color="#0A6A57" />
    <SolidColorBrush x:Key="AccentBrush" Color="#127A8A" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1A2A2E" />
    <LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#0A6A57" Offset="0" />
      <GradientStop Color="#127A8A" Offset="1" />
    </LinearGradientBrush>
    <Style TargetType="Button">
      <Setter Property="Margin" Value="4" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.9" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.75" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.5" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="Border" x:Key="CardBorderStyle">
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect Color="#12000000" BlurRadius="18" Direction="270" ShadowDepth="2" Opacity="0.35" />
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="FlowRowStyle" TargetType="DataGridRow">
      <Style.Triggers>
        <DataTrigger Binding="{Binding Type}" Value="GELEN">
          <Setter Property="Background" Value="#E7F6EC" />
        </DataTrigger>
        <DataTrigger Binding="{Binding Type}" Value="GIDEN">
          <Setter Property="Background" Value="#EAF2FB" />
        </DataTrigger>
        <DataTrigger Binding="{Binding Type}" Value="HATA">
          <Setter Property="Background" Value="#FDEBEC" />
        </DataTrigger>
        <DataTrigger Binding="{Binding Type}" Value="IN">
          <Setter Property="Background" Value="#E7F6EC" />
        </DataTrigger>
        <DataTrigger Binding="{Binding Type}" Value="OUT">
          <Setter Property="Background" Value="#EAF2FB" />
        </DataTrigger>
        <DataTrigger Binding="{Binding Type}" Value="ERROR">
          <Setter Property="Background" Value="#FDEBEC" />
        </DataTrigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>

  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="370" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{StaticResource HeroBrush}" CornerRadius="18" Padding="14,12" Margin="0,0,0,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock Text="{Binding AppWindowTitle}" FontSize="24" FontWeight="Bold" Foreground="White" />
          <TextBlock Text="Modern Bluetooth Terminal • Classic + BLE" Margin="0,2,0,0" Foreground="#D7F4EE" FontSize="13" />
        </StackPanel>
        <Border Grid.Column="1" Background="#26FFFFFF" Padding="10,6" CornerRadius="10" VerticalAlignment="Center">
          <TextBlock Text="Koza Akademi" Foreground="White" FontWeight="SemiBold" />
        </Border>
      </Grid>
    </Border>

    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,10,0">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <TextBlock Text="{Binding ScanTitle}" FontSize="20" FontWeight="SemiBold" Margin="4,2,4,8" Foreground="{StaticResource TextPrimaryBrush}" />
        <WrapPanel Margin="4,0,4,4">
          <TextBlock Text="{Binding LanguageLabelText}" VerticalAlignment="Center" Margin="0,0,8,0" />
          <ComboBox Width="140" ItemsSource="{Binding LanguageOptions}" SelectedItem="{Binding SelectedLanguage}" />
        </WrapPanel>
        <WrapPanel>
          <Button Content="{Binding ScanClassicText}" Command="{Binding ScanClassicCommand}" />
          <Button Content="{Binding ScanBleText}" Background="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}" Command="{Binding ScanBleCommand}" />
          <Button Content="{Binding AddSimulatorText}" Background="#507DBC" BorderBrush="#507DBC" Command="{Binding AddSimulatorCommand}" />
          <Button Content="{Binding OpenBtSettingsText}" Background="#3E5C76" BorderBrush="#3E5C76" Command="{Binding OpenBluetoothSettingsCommand}" />
        </WrapPanel>

        <TextBlock Text="{Binding ProfilesTitleText}" FontSize="16" FontWeight="SemiBold" Margin="4,8,4,4" Foreground="{StaticResource TextPrimaryBrush}" />
        <TextBox Margin="4,2" Text="{Binding ProfileNameInput, UpdateSourceTrigger=PropertyChanged}" />
        <ComboBox Margin="4,2" ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}" DisplayMemberPath="Name" />
        <WrapPanel>
          <Button Content="{Binding SaveProfileText}" Background="#006D77" BorderBrush="#006D77" Command="{Binding SaveProfileCommand}" />
          <Button Content="{Binding ApplyProfileText}" Background="#588157" BorderBrush="#588157" Command="{Binding ApplyProfileCommand}" />
          <Button Content="{Binding DeleteProfileText}" Background="#A44A3F" BorderBrush="#A44A3F" Command="{Binding DeleteProfileCommand}" />
        </WrapPanel>

        <ListBox Height="240" Margin="4,6,4,8"
                 ItemsSource="{Binding Devices}"
                 SelectedItem="{Binding SelectedDevice}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border CornerRadius="8" Padding="8" Margin="0,2" Background="#F7FAF9">
                <StackPanel>
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Text="{Binding DisplayId}" FontSize="11" Foreground="#5C6B73" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <WrapPanel>
          <Button Content="{Binding ConnectText}" Command="{Binding ConnectCommand}" />
          <Button Content="{Binding DisconnectText}" Background="#BC4749" BorderBrush="#BC4749" Command="{Binding DisconnectCommand}" />
          <Button Content="{Binding ReconnectText}" Background="#6A4C93" BorderBrush="#6A4C93" Command="{Binding ReconnectCommand}" />
        </WrapPanel>

        <Border Background="{Binding StatusBrush}" CornerRadius="8" Margin="4,6,4,8" Padding="9">
          <TextBlock Text="{Binding StatusText}" Foreground="White" FontWeight="SemiBold" />
        </Border>

        <TextBlock Text="{Binding SettingsTitle}" FontSize="16" FontWeight="SemiBold" Margin="4,6,4,4" Foreground="{StaticResource TextPrimaryBrush}" />

        <TextBlock Text="{Binding ComPortText}" Margin="4,2" />
        <ComboBox Margin="4,2" ItemsSource="{Binding ClassicPorts}" SelectedItem="{Binding SelectedComPort}" />

        <TextBlock Text="{Binding BaudRateText}" Margin="4,4,4,2" />
        <ComboBox Margin="4,2" ItemsSource="{Binding BaudRates}" SelectedItem="{Binding SelectedBaudRate}" />

        <Separator Margin="4,10" />

        <TextBlock Text="{Binding BleServiceText}" Margin="4,2" />
        <ComboBox Margin="4,2" ItemsSource="{Binding BleServices}" SelectedItem="{Binding SelectedBleService}" />

        <TextBlock Text="{Binding BleCharacteristicText}" Margin="4,4,4,2" />
        <ComboBox Margin="4,2" ItemsSource="{Binding BleCharacteristics}" SelectedItem="{Binding SelectedBleCharacteristic}" />

        <TextBlock Text="{Binding BleWriteModeText}" Margin="4,4,4,2" />
        <ComboBox Margin="4,2" ItemsSource="{Binding BleWriteModeOptions}" SelectedItem="{Binding SelectedBleWriteMode}" />

        <CheckBox Margin="4,6,4,0" Content="{Binding AutoReconnectText}" IsChecked="{Binding AutoReconnectEnabled}" />

        <WrapPanel Margin="0,6,0,0">
          <Button Content="{Binding LoadServicesText}" Background="#2A9D8F" BorderBrush="#2A9D8F" Command="{Binding LoadBleServicesCommand}" />
          <Button Content="{Binding LoadCharsText}" Background="#2A9D8F" BorderBrush="#2A9D8F" Command="{Binding LoadBleCharacteristicsCommand}" />
          <Button Content="{Binding ApplyBleText}" Background="#2A9D8F" BorderBrush="#2A9D8F" Command="{Binding ApplyBleSelectionCommand}" />
        </WrapPanel>

        <Separator Margin="4,10" />
        <TextBlock Text="{Binding AboutTitle}" FontSize="16" FontWeight="SemiBold" Margin="4,4,4,6" Foreground="{StaticResource TextPrimaryBrush}" />
        <CheckBox Margin="4,0,4,6" Content="{Binding HealthTelemetryText}" IsChecked="{Binding EnableHealthTelemetry}" />
        <Border Background="#F7FAF9" CornerRadius="8" Padding="8" Margin="4,0,4,4">
          <TextBlock Text="{Binding AboutText}" TextWrapping="Wrap" Foreground="#34444D" />
        </Border>
      </StackPanel>
      </ScrollViewer>
    </Border>

    <Grid Grid.Row="1" Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="170" />
        <RowDefinition Height="*" />
        <RowDefinition Height="240" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Background="#DCEFE9" Padding="10" Margin="0,0,0,8">
        <TextBlock Text="{Binding CommandTitle}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
      </Border>

      <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="10" Margin="0,0,0,8">
        <StackPanel>
          <WrapPanel Margin="0,0,0,6">
            <TextBlock Text="{Binding SendModeText}" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox Width="120" ItemsSource="{Binding CommandModeOptions}" SelectedItem="{Binding SelectedCommandMode}" />
            <TextBlock Text="{Binding LineEndingText}" VerticalAlignment="Center" Margin="14,0,8,0" />
            <ComboBox Width="120" ItemsSource="{Binding LineEndingOptions}" SelectedItem="{Binding SelectedLineEnding}" />
            <TextBlock Text="{Binding HexHintText}" VerticalAlignment="Center" Margin="14,0,0,0" Foreground="#5C6B73" />
          </WrapPanel>
          <WrapPanel>
            <TextBox Width="520" Height="34" VerticalContentAlignment="Center" Text="{Binding CommandText, UpdateSourceTrigger=PropertyChanged}" />
            <Button Content="{Binding SendText}" Command="{Binding SendCommand}" />
          </WrapPanel>
          <WrapPanel>
            <Button Content="START" Background="#1D3557" BorderBrush="#1D3557" Command="{Binding SendPresetStartCommand}" />
            <Button Content="STOP" Background="#E63946" BorderBrush="#E63946" Command="{Binding SendPresetStopCommand}" />
            <Button Content="STATUS" Background="#457B9D" BorderBrush="#457B9D" Command="{Binding SendPresetStatusCommand}" />
            <Button Content="RESET" Background="#6D597A" BorderBrush="#6D597A" Command="{Binding SendPresetResetCommand}" />
          </WrapPanel>

          <TextBlock Text="{Binding MacroTitleText}" Margin="4,10,4,2" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
          <WrapPanel>
            <TextBox Width="180" Text="{Binding MacroNameInput, UpdateSourceTrigger=PropertyChanged}" />
            <TextBox Width="340" Text="{Binding MacroCommandsInput, UpdateSourceTrigger=PropertyChanged}" />
            <TextBox Width="90" Text="{Binding MacroDelayMs, UpdateSourceTrigger=PropertyChanged}" />
          </WrapPanel>
          <WrapPanel>
            <ComboBox Width="220" ItemsSource="{Binding Macros}" SelectedItem="{Binding SelectedMacro}" DisplayMemberPath="Name" />
            <Button Content="{Binding RunMacroText}" Background="#3D5A80" BorderBrush="#3D5A80" Command="{Binding RunMacroCommand}" />
            <Button Content="{Binding SaveMacroText}" Background="#2A9D8F" BorderBrush="#2A9D8F" Command="{Binding SaveMacroCommand}" />
            <Button Content="{Binding DeleteMacroText}" Background="#BC4749" BorderBrush="#BC4749" Command="{Binding DeleteMacroCommand}" />
          </WrapPanel>

          <TextBlock Text="{Binding SchedulerTitleText}" Margin="4,10,4,2" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
          <WrapPanel>
            <TextBox Width="340" Text="{Binding SchedulerCommand, UpdateSourceTrigger=PropertyChanged}" />
            <TextBox Width="100" Text="{Binding SchedulerIntervalMs, UpdateSourceTrigger=PropertyChanged}" />
            <Button Content="{Binding StartSchedulerText}" Background="#2A9D8F" BorderBrush="#2A9D8F" Command="{Binding StartSchedulerCommand}" />
            <Button Content="{Binding StopSchedulerText}" Background="#BC4749" BorderBrush="#BC4749" Command="{Binding StopSchedulerCommand}" />
          </WrapPanel>
        </StackPanel>
      </Border>

      <GroupBox Grid.Row="2" Header="{Binding LiveFlowTitle}" Margin="0,0,0,8" FontWeight="SemiBold" Background="{StaticResource PanelBrush}">
        <DockPanel>
          <WrapPanel DockPanel.Dock="Top" HorizontalAlignment="Left" Margin="0,0,0,6">
            <TextBlock Text="{Binding TrafficFilterText}" VerticalAlignment="Center" Margin="2,0,8,0" />
            <ComboBox Width="110" ItemsSource="{Binding TrafficFilterTypes}" SelectedItem="{Binding TrafficFilterType}" />
            <TextBox Width="220" Text="{Binding TrafficFilterKeyword, UpdateSourceTrigger=PropertyChanged}" />
          </WrapPanel>
          <WrapPanel DockPanel.Dock="Top" HorizontalAlignment="Right" Margin="0,0,0,6">
            <Button Content="{Binding ClearFlowText}" Background="#607D8B" BorderBrush="#607D8B" Command="{Binding ClearTrafficCommand}" />
            <Button Content="{Binding ExportFlowText}" Background="#2A9D8F" BorderBrush="#2A9D8F" Command="{Binding ExportTrafficCsvCommand}" />
          </WrapPanel>
          <DataGrid ItemsSource="{Binding TrafficView}" IsReadOnly="True" AutoGenerateColumns="False" RowHeight="30" HeadersVisibility="Column" RowStyle="{StaticResource FlowRowStyle}">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Saat" Binding="{Binding Timestamp}" Width="150" />
            <DataGridTextColumn Header="Akış" Binding="{Binding Type}" Width="110" />
            <DataGridTextColumn Header="İçerik" Binding="{Binding Message}" Width="*" />
          </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </GroupBox>

      <GroupBox Grid.Row="3" Header="{Binding LogTitle}" FontWeight="SemiBold" Background="{StaticResource PanelBrush}">
        <DockPanel>
          <WrapPanel DockPanel.Dock="Top" HorizontalAlignment="Right" Margin="0,0,0,6">
            <Button Content="{Binding ClearLogsText}" Background="#607D8B" BorderBrush="#607D8B" Command="{Binding ClearLogsCommand}" />
            <Button Content="{Binding ExportLogText}" Background="#457B9D" BorderBrush="#457B9D" Command="{Binding ExportLogsTxtCommand}" />
          </WrapPanel>
          <DataGrid ItemsSource="{Binding Logs}" IsReadOnly="True" AutoGenerateColumns="False" RowHeight="30" HeadersVisibility="Column">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Saat" Binding="{Binding Timestamp}" Width="150" />
            <DataGridTextColumn Header="Tip" Binding="{Binding Type}" Width="120" />
            <DataGridTextColumn Header="Mesaj" Binding="{Binding Message}" Width="*" />
          </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </GroupBox>

      <StatusBar Grid.Row="4" Background="#DCEFE9">
        <StatusBarItem Content="{Binding GitInfoText}" />
      </StatusBar>
    </Grid>
  </Grid>
</Window>
