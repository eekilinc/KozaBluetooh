<Window x:Class="BluetoothDeskApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding AppWindowTitle}" Height="780" Width="1260" WindowStartupLocation="CenterScreen" WindowState="Maximized"
        Background="#F2F5F7" FontFamily="Bahnschrift">
  <Window.Resources>
    <DrawingImage x:Key="AppIcon">
      <DrawingImage.Drawing>
        <DrawingGroup>
          <GeometryDrawing Brush="#0F766E" Geometry="F1 M 32,8 C 45.255,8 56,18.745 56,32 56,45.255 45.255,56 32,56 18.745,56 8,45.255 8,32 8,18.745 18.745,8 32,8 Z"/>
          <GeometryDrawing Brush="#FFFFFF" Geometry="F1 M 20,20 L 28,20 28,30 34,20 43,20 34,32 44,44 35,44 28,34 28,44 20,44 Z"/>
        </DrawingGroup>
      </DrawingImage.Drawing>
    </DrawingImage>
    <SolidColorBrush x:Key="PrimaryBrush" Color="#0F766E" />
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#5F6B73" />
    <Style TargetType="Button">
      <Setter Property="Margin" Value="4" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style TargetType="GroupBox">
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>
    <Style x:Key="CardStyle" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="10" />
    </Style>
    <Style x:Key="FlowRowStyle" TargetType="DataGridRow">
      <Style.Triggers>
        <DataTrigger Binding="{Binding Type}" Value="GELEN">
          <Setter Property="Background" Value="#EAF8F1" />
        </DataTrigger>
        <DataTrigger Binding="{Binding Type}" Value="GIDEN">
          <Setter Property="Background" Value="#EDF4FF" />
        </DataTrigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>

  <DockPanel>
    <Menu DockPanel.Dock="Top" Background="White">
      <MenuItem Header="Dosya">
        <MenuItem Header="Çıkış" Click="OnExitClick" />
      </MenuItem>
      <MenuItem Header="Görünüm">
        <MenuItem Header="Tam Ekran" IsCheckable="True" IsChecked="True" Click="OnFullscreenToggleClick" />
      </MenuItem>
      <MenuItem Header="Araçlar">
        <MenuItem Header="Bluetooth Ayarları" Command="{Binding OpenBluetoothSettingsCommand}" />
      </MenuItem>
      <MenuItem Header="Yardım">
        <MenuItem Header="Hakkında" Click="OnAboutClick" />
      </MenuItem>
    </Menu>

    <Grid Margin="10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="330" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <StackPanel Grid.Row="0">
            <TextBlock Text="Bağlantı" FontSize="20" FontWeight="SemiBold" />
            <WrapPanel Margin="0,6,0,0">
              <TextBlock Text="{Binding LanguageLabelText}" VerticalAlignment="Center" Margin="0,0,8,0" />
              <ComboBox Width="130" ItemsSource="{Binding LanguageOptions}" SelectedItem="{Binding SelectedLanguage}" />
            </WrapPanel>
          </StackPanel>

          <WrapPanel Grid.Row="1" Margin="0,8,0,8">
            <Button Content="{Binding ScanClassicText}" Command="{Binding ScanClassicCommand}" />
            <Button Content="{Binding ScanBleText}" Background="#2563EB" Command="{Binding ScanBleCommand}" />
            <Button Content="{Binding AddSimulatorText}" Background="#475569" Command="{Binding AddSimulatorCommand}" />
          </WrapPanel>

          <WrapPanel Grid.Row="2" Margin="0,0,0,8">
            <Button Content="{Binding ConnectText}" Command="{Binding ConnectCommand}" />
            <Button Content="{Binding DisconnectText}" Background="#DC2626" Command="{Binding DisconnectCommand}" />
            <Button Content="{Binding ReconnectText}" Background="#7C3AED" Command="{Binding ReconnectCommand}" />
          </WrapPanel>

          <ListBox Grid.Row="3" Margin="0,0,0,8"
                   ItemsSource="{Binding Devices}"
                   SelectedItem="{Binding SelectedDevice}">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="2">
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding DisplayId}" FontSize="11" Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <Border Grid.Row="4" Background="{Binding StatusBrush}" CornerRadius="8" Padding="8">
            <TextBlock Text="{Binding StatusText}" Foreground="White" FontWeight="SemiBold" />
          </Border>
        </Grid>
      </Border>

      <Border Grid.Column="1" Style="{StaticResource CardStyle}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Text="{Binding CommandTitle}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8" />

          <TabControl Grid.Row="1">
            <TabItem Header="Terminal">
              <Grid Margin="8">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0" Margin="0,0,0,6">
                  <TextBlock Text="{Binding SendModeText}" VerticalAlignment="Center" Margin="0,0,8,0" />
                  <ComboBox Width="120" ItemsSource="{Binding CommandModeOptions}" SelectedItem="{Binding SelectedCommandMode}" />
                  <TextBlock Text="{Binding LineEndingText}" VerticalAlignment="Center" Margin="12,0,8,0" />
                  <ComboBox Width="120" ItemsSource="{Binding LineEndingOptions}" SelectedItem="{Binding SelectedLineEnding}" />
                  <TextBlock Text="{Binding HexHintText}" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{StaticResource MutedTextBrush}" />
                </WrapPanel>

                <StackPanel Grid.Row="1" Margin="0,0,0,6">
                  <WrapPanel>
                    <TextBox Width="560" Height="32" Text="{Binding CommandText, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" />
                    <Button Content="{Binding SendText}" Command="{Binding SendCommand}" />
                  </WrapPanel>
                  <WrapPanel>
                    <Button Content="START" Command="{Binding SendPresetStartCommand}" Background="#1D4ED8" />
                    <Button Content="STOP" Command="{Binding SendPresetStopCommand}" Background="#B91C1C" />
                    <Button Content="STATUS" Command="{Binding SendPresetStatusCommand}" Background="#0369A1" />
                    <Button Content="RESET" Command="{Binding SendPresetResetCommand}" Background="#6D28D9" />
                  </WrapPanel>
                </StackPanel>

                <GroupBox Grid.Row="2" Header="{Binding LiveFlowTitle}">
                  <DockPanel>
                    <WrapPanel DockPanel.Dock="Top" HorizontalAlignment="Left" Margin="0,0,0,6">
                      <TextBlock Text="{Binding TrafficFilterText}" VerticalAlignment="Center" Margin="0,0,8,0" />
                      <ComboBox Width="110" ItemsSource="{Binding TrafficFilterTypes}" SelectedItem="{Binding TrafficFilterType}" />
                      <TextBox Width="220" Text="{Binding TrafficFilterKeyword, UpdateSourceTrigger=PropertyChanged}" />
                    </WrapPanel>
                    <WrapPanel DockPanel.Dock="Top" HorizontalAlignment="Right" Margin="0,0,0,6">
                      <Button Content="{Binding ClearFlowText}" Background="#475569" Command="{Binding ClearTrafficCommand}" />
                      <Button Content="{Binding ExportFlowText}" Background="#0E7490" Command="{Binding ExportTrafficCsvCommand}" />
                    </WrapPanel>
                    <DataGrid ItemsSource="{Binding TrafficView}" IsReadOnly="True" AutoGenerateColumns="False" RowHeight="28" RowStyle="{StaticResource FlowRowStyle}" EnableRowVirtualization="True" EnableColumnVirtualization="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" ScrollViewer.CanContentScroll="True">
                      <DataGrid.Columns>
                        <DataGridTextColumn Header="Saat" Binding="{Binding Timestamp}" Width="140" />
                        <DataGridTextColumn Header="Akış" Binding="{Binding Type}" Width="90" />
                        <DataGridTextColumn Header="İçerik" Binding="{Binding Message}" Width="*" />
                      </DataGrid.Columns>
                    </DataGrid>
                  </DockPanel>
                </GroupBox>
              </Grid>
            </TabItem>

            <TabItem Header="Log">
              <Grid Margin="8">
                <GroupBox Header="{Binding LogTitle}">
                  <DockPanel>
                    <WrapPanel DockPanel.Dock="Top" HorizontalAlignment="Right" Margin="0,0,0,6">
                      <Button Content="{Binding ClearLogsText}" Background="#475569" Command="{Binding ClearLogsCommand}" />
                      <Button Content="{Binding ExportLogText}" Background="#0369A1" Command="{Binding ExportLogsTxtCommand}" />
                    </WrapPanel>
                    <DataGrid ItemsSource="{Binding Logs}" IsReadOnly="True" AutoGenerateColumns="False" RowHeight="28" EnableRowVirtualization="True" EnableColumnVirtualization="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" ScrollViewer.CanContentScroll="True">
                      <DataGrid.Columns>
                        <DataGridTextColumn Header="Saat" Binding="{Binding Timestamp}" Width="140" />
                        <DataGridTextColumn Header="Tip" Binding="{Binding Type}" Width="100" />
                        <DataGridTextColumn Header="Mesaj" Binding="{Binding Message}" Width="*" />
                      </DataGrid.Columns>
                    </DataGrid>
                  </DockPanel>
                </GroupBox>
              </Grid>
            </TabItem>

            <TabItem Header="Gelişmiş">
              <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8">
                <StackPanel>
                  <GroupBox Header="Ayarlar">
                    <StackPanel>
                      <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="200" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding ComPortText}" Margin="0,6" />
                        <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding ClassicPorts}" SelectedItem="{Binding SelectedComPort}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding BaudRateText}" Margin="0,6" />
                        <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding BaudRates}" SelectedItem="{Binding SelectedBaudRate}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding BleServiceText}" Margin="0,6" />
                        <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding BleServices}" SelectedItem="{Binding SelectedBleService}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding BleCharacteristicText}" Margin="0,6" />
                        <ComboBox Grid.Row="3" Grid.Column="1" ItemsSource="{Binding BleCharacteristics}" SelectedItem="{Binding SelectedBleCharacteristic}" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding BleWriteModeText}" Margin="0,6" />
                        <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding BleWriteModeOptions}" SelectedItem="{Binding SelectedBleWriteMode}" />
                      </Grid>
                      <WrapPanel>
                        <Button Content="{Binding LoadServicesText}" Command="{Binding LoadBleServicesCommand}" />
                        <Button Content="{Binding LoadCharsText}" Command="{Binding LoadBleCharacteristicsCommand}" />
                        <Button Content="{Binding ApplyBleText}" Command="{Binding ApplyBleSelectionCommand}" />
                      </WrapPanel>
                      <WrapPanel>
                        <CheckBox Content="{Binding AutoReconnectText}" IsChecked="{Binding AutoReconnectEnabled}" Margin="4" />
                        <CheckBox Content="{Binding HealthTelemetryText}" IsChecked="{Binding EnableHealthTelemetry}" Margin="4" />
                      </WrapPanel>
                    </StackPanel>
                  </GroupBox>

                  <GroupBox Header="{Binding ProfilesTitleText}">
                    <WrapPanel>
                      <TextBox Width="180" Text="{Binding ProfileNameInput, UpdateSourceTrigger=PropertyChanged}" />
                      <ComboBox Width="220" ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}" DisplayMemberPath="Name" />
                      <Button Content="{Binding SaveProfileText}" Command="{Binding SaveProfileCommand}" />
                      <Button Content="{Binding ApplyProfileText}" Background="#15803D" Command="{Binding ApplyProfileCommand}" />
                      <Button Content="{Binding DeleteProfileText}" Background="#B91C1C" Command="{Binding DeleteProfileCommand}" />
                    </WrapPanel>
                  </GroupBox>

                  <GroupBox Header="{Binding MacroTitleText}">
                    <StackPanel>
                      <WrapPanel>
                        <TextBox Width="170" Text="{Binding MacroNameInput, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Width="380" Text="{Binding MacroCommandsInput, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Width="90" Text="{Binding MacroDelayMs, UpdateSourceTrigger=PropertyChanged}" />
                      </WrapPanel>
                      <WrapPanel>
                        <ComboBox Width="220" ItemsSource="{Binding Macros}" SelectedItem="{Binding SelectedMacro}" DisplayMemberPath="Name" />
                        <Button Content="{Binding RunMacroText}" Background="#1D4ED8" Command="{Binding RunMacroCommand}" />
                        <Button Content="{Binding SaveMacroText}" Command="{Binding SaveMacroCommand}" />
                        <Button Content="{Binding DeleteMacroText}" Background="#B91C1C" Command="{Binding DeleteMacroCommand}" />
                      </WrapPanel>
                    </StackPanel>
                  </GroupBox>

                  <GroupBox Header="{Binding SchedulerTitleText}">
                    <WrapPanel>
                      <TextBox Width="360" Text="{Binding SchedulerCommand, UpdateSourceTrigger=PropertyChanged}" />
                      <TextBox Width="100" Text="{Binding SchedulerIntervalMs, UpdateSourceTrigger=PropertyChanged}" />
                      <Button Content="{Binding StartSchedulerText}" Command="{Binding StartSchedulerCommand}" />
                      <Button Content="{Binding StopSchedulerText}" Background="#B91C1C" Command="{Binding StopSchedulerCommand}" />
                    </WrapPanel>
                  </GroupBox>
                </StackPanel>
              </ScrollViewer>
            </TabItem>
          </TabControl>

          <StatusBar Grid.Row="2" Background="#EEF2F4">
            <StatusBarItem Content="{Binding GitInfoText}" />
          </StatusBar>
        </Grid>
      </Border>
    </Grid>
  </DockPanel>
</Window>
